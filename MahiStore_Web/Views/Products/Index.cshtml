@model List<Product>

    <h1 class="text-center mb-5">List of the Products</h1>
    <div class="row mb-5">
        <div class="col">
            <a class="btn btn-primary" asp-controller="Produscts" asp-action="Create"> New Product</a>
        </div>
        <div class="col">

        </div>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Brand</th>
                <th>Category</th>
                <th>Price</th>
                <th>Image</th>
                <th>Created On</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach(var product in Model)
            {
            <tr>
                <td>@product.Id</td>
                <td>@product.Brand</td>
                <td>@product.Category</td>
                <td>@(product.Price) &#8377</td>
                <td><img src="/products/@product.ImageFileName" width="100" /></td>
                <td>@product.CreatedAt.ToString("dd/mm/yyyy")</td>
                <td style="white-space:nowrap">
                    <a class="btn btn-primary" asp-controller="Products" asp-action="Edit" asp-route-id="@product.Id">Edit</a>
                    <a class="btn btn-danger" asp-controller="Products" asp-action="Delete" asp-route-id="@product.Id">Delete</a>
                </td>
               
            </tr>
        }
        </tbody>
    </table>
