@model ProductDTO

@{

}

<div class="row">
    <div class="col-md-8 mx-auto rounded border p-3">
        <h2 class="text-center mb-5"> Edit Products</h2>
        @*  <a class="btn btn-secondary mb-3" asp-controller="Products" asp-action="Index">Back to List</a> *@
        <form method="post" enctype="multipart/form-data">
            <div class="row mb-3">
                <label for="Name" class="col-sm-4 form-label">Id</label>
                <div class="col-sm-8">
                    <input class="form-control-plaintext" readonly value="@ViewData["ProductId"]" />
                </div>
            </div>

            <div class="row mb-3">
                <label for="Name" class="col-sm-4 form-label">Name</label>
                <div class="col-sm-8">
                    <input type="text" class="form-control" asp-for="Name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-3">
                <label for="Brand" class="col-sm-4 form-label">Brand</label>
                <div class="col-sm-8">
                    <input type="text" class="form-control" asp-for="Brand" />
                    <span asp-validation-for="Brand" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <label for="Category" class="col-sm-4 col-form-label">Category</label>
                <div class="col-sm-8">
                    <select class="form-select" asp-for="Category">
                        <option value="">Select a category</option>
                        <option value="Phones">Phons</option>
                        <option value="Computers">Computers</option>
                        <option value="Cameras">Cameras</option>
                        <option value="Accessories">Accessories</option>
                        <option value="Printers">Printers</option>
                    </select>
                </div>
            </div>
            <div class="row mb-3">
                <label for="Price" class="col-sm-4 form-label">Price</label>
                <div class="col-sm-8">
                    <input type="text" class="form-control" asp-for="Price" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <label for="Description" class="col-sm-4 form-label">Description</label>
                <div class="col-sm-8">
                    <textarea type="text" class="form-control" asp-for="Description"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="offset-sm-4 col-sm-8">
                    <img src="/Productimages/@ViewData["ImageFile"]" width="150" />
                 </div>
            </div>
            <div class="row mb-3">
                <label for="ImageFile" class="col-sm-4 form-label">Image</label>
                <div class="col-sm-8">
                    <input type="file" class="form-control" asp-for="ImageFile" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <label for="CreatedAt" class="col-sm-4 form-label">CreatedAt</label>
                <div class="col-sm-8">
                    <input class="form-control-plaintext" value="@ViewData["CreatedDate"]" readonly />
                   
                </div>
            </div>
            <div class="row">
                <div class="offset-sm-4 col-sm-4 d-grid">
                    <button type="submit" class="btn btn-primary">Update</button>
                </div>
                <div class="col-sm-4 d-grid">
                    <a class="btn btn-outline-primary" asp-controller="Products" asp-action="Index" role="button">Cancel</a>
                </div>
            </div>

        </form>
    </div>
</div>
